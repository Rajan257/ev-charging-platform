{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://ev-charging-platform-iz4z.onrender.com/api/v1/:path*"
    },
    {
      "source": "/ocpi/:path*",
      "destination": "https://ev-charging-platform-iz4z.onrender.com/ocpi/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
